  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../../dist/convex-component",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"]
