{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,

    "target": "ESNext",
    "lib": ["ES2023", "dom", "DOM.Iterable"],
    // Convex codegen emits `export const env = process.env` in _generated/server
    // when a component declares typed env vars — needs the Node `process` global.
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noErrorTruncation": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "composite": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["./src/convex/**/*"]
}
