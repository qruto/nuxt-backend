{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src/convex-component",
    "outDir": "./dist/convex-component",
    "types": ["node"]
  },
  "include": ["src/convex-component/**/*"],
  "exclude": ["src/convex-component/**/*.test.*"]
}
