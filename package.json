{
  "name": "nuxt-convex-backend",
  "version": "1.0.0",
  "description": "Nuxt module for Convex backend integration, including authentication and permissions",
  "repository": "qruto/nuxt-convex-backend",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e",
    "bump": "npx taze major -w"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "^1.0.3",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/node": "latest",
    "@unhead/vue": "^3.0.2",
    "@vue/test-utils": "^2.4.6",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.0",
    "happy-dom": "^20.8.9",
    "nuxt": "^4.4.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
