{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "nuxt-backend",
  "version": "0.1.0",
  "description": "Nuxt module and Convex component for a full-stack Convex backend with authentication",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qruto/nuxt-backend.git"
  },
  "license": "MIT",
  "author": "Slava Razum <razum@qruto.to>",
  "homepage": "https://github.com/qruto/nuxt-backend#readme",
  "bugs": {
    "url": "https://github.com/qruto/nuxt-backend/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/qruto"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "convex",
    "authentication",
    "auth",
    "better-auth",
    "backend",
    "fullstack"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.js"
    },
    "./convex": {
      "types": "./dist/convex/client/index.d.ts",
      "default": "./dist/convex/client/index.js"
    },
    "./convex/app": {
      "types": "./dist/convex/app.d.ts",
      "default": "./dist/convex/app.js"
    },
    "./convex/billing": {
      "types": "./dist/convex/integrations/billing.d.ts",
      "default": "./dist/convex/integrations/billing.js"
    },
    "./convex/email": {
      "types": "./dist/convex/integrations/email.d.ts",
      "default": "./dist/convex/integrations/email.js"
    },
    "./convex/rate-limit": {
      "types": "./dist/convex/integrations/rate-limit.d.ts",
      "default": "./dist/convex/integrations/rate-limit.js"
    },
    "./convex/migrations": {
      "types": "./dist/convex/integrations/migrations.d.ts",
      "default": "./dist/convex/integrations/migrations.js"
    },
    "./convex/aggregate": {
      "types": "./dist/convex/integrations/aggregate.d.ts",
      "default": "./dist/convex/integrations/aggregate.js"
    },
    "./convex/search": {
      "types": "./dist/convex/integrations/search.d.ts",
      "default": "./dist/convex/integrations/search.js"
    },
    "./convex/workflows": {
      "types": "./dist/convex/integrations/workflows.d.ts",
      "default": "./dist/convex/integrations/workflows.js"
    },
    "./convex/component/_generated/component": {
      "types": "./dist/convex/component/_generated/component.d.ts"
    },
    "./convex/component/convex.config": {
      "types": "./dist/convex/component/convex.config.d.ts",
      "default": "./dist/convex/component/convex.config.js"
    },
    "./convex/component/schema": {
      "types": "./dist/convex/component/schema.d.ts",
      "default": "./dist/convex/component/schema.js"
    },
    "./convex/auth.config": {
      "types": "./dist/convex/auth.config.d.ts",
      "default": "./dist/convex/auth.config.js"
    },
    "./convex/test": "./src/convex/test.ts"
  },
  "main": "./dist/module.js",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.ts"
      ],
      "convex": [
        "./dist/convex/client/index.d.ts"
      ],
      "convex/app": [
        "./dist/convex/app.d.ts"
      ],
      "convex/billing": [
        "./dist/convex/integrations/billing.d.ts"
      ],
      "convex/email": [
        "./dist/convex/integrations/email.d.ts"
      ],
      "convex/rate-limit": [
        "./dist/convex/integrations/rate-limit.d.ts"
      ],
      "convex/migrations": [
        "./dist/convex/integrations/migrations.d.ts"
      ],
      "convex/aggregate": [
        "./dist/convex/integrations/aggregate.d.ts"
      ],
      "convex/search": [
        "./dist/convex/integrations/search.d.ts"
      ],
      "convex/workflows": [
        "./dist/convex/integrations/workflows.d.ts"
      ],
      "convex/component/_generated/component": [
        "./dist/convex/component/_generated/component.d.ts"
      ],
      "convex/component/convex.config": [
        "./dist/convex/component/convex.config.d.ts"
      ],
      "convex/component/schema": [
        "./dist/convex/component/schema.d.ts"
      ],
      "convex/auth.config": [
        "./dist/convex/auth.config.d.ts"
      ],
      "convex/test": [
        "./src/convex/test.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src/convex"
  ],
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "prepare": "git config hook.commitlint.event commit-msg && git config hook.commitlint.command 'pnpm exec commitlint --edit' || true",
    "prepack": "pnpm run build",
    "build": "pnpm run build:nuxt-module && pnpm run build:convex-component",
    "build:nuxt-module": "nuxt-module-build build && node scripts/normalize-module-ext.js",
    "build:convex-component": "tsc --project ./tsconfig.convex-component.build.json && node -e \"require('fs').utimesSync('website/backend/convex.config.ts', new Date(), new Date())\"",
    "analyze": "ANALYZE=true nuxt build --dotenv ../.env.local website",
    "dev": "pnpm run dev:prepare && pnpm run build:convex-component && run-p -r 'dev:convex-component' 'dev:nuxt-module'",
    "dev:convex-component": "convex dev --typecheck-components --start 'pnpm run dev:convex-component:watch'",
    "dev:convex-component:codegen": "convex codegen --component-dir ./src/convex/component",
    "dev:convex-component:watch": "chokidar 'tsconfig*.json' 'src/convex/**/*.ts' -i '**/*.test.ts' -i 'src/convex/component/_generated/**' -c 'pnpm run dev:convex-component:codegen && pnpm run build:convex-component' --initial",
    "dev:nuxt-module": "portless nuxt-backend nuxt dev --dotenv ../.env.local website",
    "dev:nuxt-module:share": "portless nuxt-backend --ngrok nuxt dev --dotenv ../.env.local website",
    "dev:nuxt-module:build": "nuxt build --dotenv ../.env.local website",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && node scripts/normalize-module-ext.js && nuxt prepare website",
    "dev:nuxt-module:prepare": "pnpm run dev:prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "test:types": "pnpm run test:types:lib && cd website && vue-tsc --noEmit",
    "test:types:lib": "pnpm run dev:prepare && pnpm run build:convex-component && vue-tsc --noEmit && tsc --noEmit -p tsconfig.convex.json",
    "test:unit": "vitest --project unit --run",
    "test:nuxt": "vitest --project nuxt --run",
    "test:e2e": "vitest --project e2e --run",
    "test:convex-component": "vitest --project convex-component --run",
    "test:quality": "fallow",
    "bump": "pnpm exec taze major -w",
    "db:reset": "node scripts/db-reset.js"
  },
  "dependencies": {
    "@better-auth/passkey": "~1.6.23",
    "@convex-dev/aggregate": "^0.2.2",
    "@convex-dev/better-auth": "^0.12.5",
    "@convex-dev/migrations": "^0.3.5",
    "@convex-dev/polar": "^0.9.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.5",
    "@convex-dev/workflow": "^0.4.4",
    "@nuxt/kit": "^4.4.8",
    "@polar-sh/checkout": "^0.3.0",
    "@polar-sh/sdk": "^0.48.1",
    "better-auth": "~1.6.23",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120",
    "dedent": "^1.7.2",
    "nuxt-security": "^2.6.0",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@codecov/nuxt-plugin": "^2.0.1",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "@unhead/vue": "^3.1.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "changelogen": "^0.6.2",
    "changelogithub": "^14.0.0",
    "chokidar-cli": "^3.0.0",
    "convex-test": "^0.0.54",
    "eslint": "^10.6.0",
    "fallow": "^2.103.0",
    "happy-dom": "^20.10.6",
    "npm-run-all2": "^8.0.4",
    "nuxt": "catalog:",
    "oxc-parser": "^0.138.0",
    "portless": "^0.15.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6",
    "ws": "^8.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
