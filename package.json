{
  "name": "nuxt-backend",
  "version": "1.0.0",
  "description": "Batteries-included Nuxt module for Convex backend with authentication",
  "repository": "qruto/nuxt-backend",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./convex-component": {
      "types": "./dist/convex-component/config.d.ts",
      "import": "./src/convex-component/config.ts"
    },
    "./auth-config": {
      "types": "./dist/convex-component/auth-config.d.ts",
      "import": "./src/convex-component/auth-config.ts"
    },
    "./auth": {
      "types": "./dist/convex-component/auth.d.ts",
      "import": "./src/convex-component/auth.ts"
    },
    "./test": "./src/convex-component/test.ts"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "convex-component": [
        "./dist/convex-component/config.d.ts"
      ],
      "backend-component": [
        "./dist/convex-component/config.d.ts"
      ],
      "auth-config": [
        "./dist/convex-component/auth-config.d.ts"
      ],
      "auth": [
        "./dist/convex-component/auth.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "convex codegen --component-dir ./src/convex-component && nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:types": "npm run dev:prepare && vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "test:unit": "vitest --project unit",
    "test:convex": "vitest --project convex-component",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e",
    "bump": "npx taze major -w"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "@nuxt/kit": "^4.4.2",
    "better-auth": "^1.6.2",
    "convex": "^1.35.1"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/node": "latest",
    "@unhead/vue": "^3.0.3",
    "@vue/test-utils": "^2.4.6",
    "changelogen": "^0.6.2",
    "convex-test": "^0.0.47",
    "eslint": "^10.2.0",
    "happy-dom": "^20.8.9",
    "nuxt": "^4.4.2",
    "oxc-parser": "^0.124.0",
    "pkg-pr-new": "^0.0.66",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
