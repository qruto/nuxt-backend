{
  "name": "nuxt-backend",
  "version": "1.0.0",
  "description": "Nuxt module and Convex component for a full-stack Convex backend with authentication",
  "repository": "qruto/nuxt-backend",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./convex": {
      "types": "./dist/convex/client/index.d.ts",
      "default": "./dist/convex/client/index.js"
    },
    "./convex/component/_generated/component": {
      "types": "./dist/convex/component/_generated/component.d.ts"
    },
    "./convex/component/convex.config": {
      "types": "./dist/convex/component/convex.config.d.ts",
      "default": "./dist/convex/component/convex.config.js"
    },
    "./convex/component/schema": {
      "types": "./dist/convex/component/schema.d.ts",
      "default": "./dist/convex/component/schema.js"
    },
    "./convex/auth.config": {
      "types": "./dist/convex/auth.config.d.ts",
      "default": "./dist/convex/auth.config.js"
    },
    "./convex/test": "./src/convex/test.ts"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "convex": [
        "./dist/convex/client/index.d.ts"
      ],
      "convex/component/_generated/component": [
        "./dist/convex/component/_generated/component.d.ts"
      ],
      "convex/component/convex.config": [
        "./dist/convex/component/convex.config.d.ts"
      ],
      "convex/component/schema": [
        "./dist/convex/component/schema.d.ts"
      ],
      "convex/auth.config": [
        "./dist/convex/auth.config.d.ts"
      ],
      "convex/test": [
        "./src/convex/test.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "npm run build:nuxt-module && npm run build:convex-component",
    "build:nuxt-module": "nuxt-module-build build",
    "build:convex-component": "npx convex codegen --component-dir ./src/convex/component && tsc --project ./tsconfig.convex-component.build.json && node -e \"require('fs').utimesSync('playground/backend/convex.config.ts', new Date(), new Date())\"",
    "dev": "npm run dev:nuxt-module:prepare && npm run build:convex-component && run-p -r 'dev:convex-component' 'dev:nuxt-module'",
    "dev:convex-component": "convex dev --typecheck-components --start 'npm run dev:convex-component:watch'",
    "dev:convex-component:watch": "chokidar 'tsconfig*.json' 'src/convex/**/*.ts' -i '**/*.test.ts' -i 'src/convex/component/_generated/**' -c 'npm run build:convex-component' --initial",
    "dev:nuxt-module": "TMPDIR=/tmp portless nuxt-backend nuxt dev playground",
    "dev:nuxt-module:build": "nuxt build playground",
    "dev:nuxt-module:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:types": "npm run dev:nuxt-module:prepare && npm run build:convex-component && vue-tsc --noEmit && tsc --noEmit -p tsconfig.convex.json && cd playground && vue-tsc --noEmit",
    "test:unit": "vitest --project unit --run",
    "test:nuxt": "vitest --project nuxt --run",
    "test:e2e": "vitest --project e2e --run",
    "test:convex-component": "vitest --project convex-component --run",
    "test:quality": "fallow --summary",
    "bump": "npx taze major -w",
    "db:reset": "node scripts/db-reset.mjs"
  },
  "dependencies": {
    "@better-auth/passkey": "~1.6.11",
    "@convex-dev/better-auth": "^0.12.2",
    "@nuxt/kit": "^4.4.5",
    "better-auth": "~1.6.11",
    "convex": "^1.40.0",
    "dedent": "^1.7.2"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.5",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "@unhead/vue": "^3.1.0",
    "@vue/test-utils": "^2.4.10",
    "changelogen": "^0.6.2",
    "chokidar-cli": "^3.0.0",
    "convex-test": "^0.0.52",
    "eslint": "^10.4.0",
    "fallow": "^2.80.0",
    "happy-dom": "^20.9.0",
    "npm-run-all2": "^8.0.4",
    "nuxt": "^4.4.5",
    "oxc-parser": "^0.131.0",
    "pkg-pr-new": "^0.0.73",
    "portless": "^0.13.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9",
    "ws": "^8.20.0"
  }
}
